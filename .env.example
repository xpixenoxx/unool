# Supabase (REQUIRED - get from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# Encryption Key (REQUIRED - generate: openssl rand -base64 32)
ENCRYPTION_KEY=
ENCRYPTION_KEY_VERSION=1

# Upstash QStash (REQUIRED - get from https://console.upstash.com/qstash)
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Upstash Redis (REQUIRED - get from https://console.upstash.com/redis)
UPSTASH_REDIS_REST_URL=https://ready-sunfish-xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Anthropic API (REQUIRED - get from https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-api03-xxx
ANTHROPIC_MODEL=claude-sonnet-5
AI_DEFAULT_MODEL=claude-sonnet-5

# OpenAI (optional fallback)
OPENAI_API_KEY=sk-proj-xxx
AI_OPENAI_MODEL=gpt-4o-mini

# OAuth: LinkedIn (get from https://www.linkedin.com/developers/apps)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Production: https://unool.co/api/auth/platform/callback
# Local: http://localhost:3000/api/auth/platform/callback
LINKEDIN_REDIRECT_URI=https://unool.co/api/auth/platform/callback

# OAuth: X/Twitter (get from https://developer.twitter.com/en/portal/dashboard)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=https://unool.co/api/auth/platform/callback

# OAuth: Meta/Threads (get from https://developers.facebook.com/apps/)
META_CLIENT_ID=
META_CLIENT_SECRET=
META_REDIRECT_URI=https://unool.co/api/auth/platform/callback

# Webhook Secrets (generate random strings)
LINKEDIN_WEBHOOK_SECRET=
X_WEBHOOK_SECRET=
META_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=https://unool.co
DEV_AUTH_BYPASS=false

# Sentry (optional - for production error tracking)
SENTRY_DSN=

# Rate Limits
RATE_LIMIT_AI_PER_MIN=20
RATE_LIMIT_PUBLISH_PER_MIN=10
RATE_LIMIT_AUTH_PER_HOUR=5
AI_MAX_TOKENS_PER_REQUEST=4000
AI_DAILY_TOKEN_BUDGET=50000